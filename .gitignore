# OS
Thumbs.db
.DS_Store

# Editors
.vscode/
.idea/

# Temp
*.tmp
*.log

# Python bytecode
__pycache__/

# Python (uv)
.venv/
*.egg-info/

# Node / pnpm
node_modules/
.pnpm-store/

# Web build output
dist/
apps/site/.astro/
apps/*/node_modules/.tmp/

# Playwright
test-results/
playwright-report/
blob-report/

# ローカル運用データ（plan.md §2.1: SQLite・生成物はGit対象外）
artifacts/
*.sqlite3
*.sqlite3-*

# >>> guardrails-kit >>>（この区画はキットの正本。既存 .gitignore がある場合、
# install_kit.py はこの区画ごと末尾へ追記する——区画外は各プロジェクトの自由領域）
__pycache__/
*.pyc
# generate_structure.py の原子的書き込みが中断された場合の残骸（§7.4。静かな混入を防ぐ — G9）
.STRUCTURE.md.*.tmp
# Stop ゲート等のセッション状態（§2b。追跡すると porcelain が恒常非空＝ゲート誤発火）
.claude/session/
# Codex フックのセッション状態（baseline / Stop 再試行カウンタ）
.codex/session/
# red-first 証明の一時 worktree（§5。中断で残骸が出ても dirty 扱いにしない — v2.7）
.red-first-*/
# commit-msg 系ゲートの履歴再検査の一時 worktree（§3.4。v2.30）
.commit-msg-history-*/
# 違反ログ（§3.6。v2.34。ローカル telemetry——追跡するとコミットノイズ＆機械記録の改変面）
.guardrails/violations.jsonl
# <<< guardrails-kit <<<
