---
// episodes/[id]/index.astro — エピソード詳細(最新版)。出典・主張対応・訂正履歴・関連書籍・音声を表示する
// (plan.md Phase 2「詳細」「出典」「訂正履歴」。development-plan.md Phase 8タスク2で過去版一覧を追加)。
import { getCollection, getEntry, render } from "astro:content";
import EpisodeDetail from "../../../components/EpisodeDetail.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
	// versions/<revision>.md のアーカイブ済みスナップショットは除外し、現行版ポインタだけを対象にする
	// (同じepisodeIdで複数の静的パスが衝突しないように)。
	const episodes = await getCollection(
		"episodes",
		(entry) => !entry.id.includes("/versions/"),
	);
	return episodes.map((episode) => ({
		params: { id: episode.data.episodeId },
		props: { slug: episode.id },
	}));
}

interface Props {
	slug: string;
}

const { slug } = Astro.props as Props;
const episode = await getEntry("episodes", slug);
if (!episode) {
	// getStaticPaths が返したslugのはずなので到達しない——ビルド決定性が壊れた合図として落とす。
	throw new Error(`episodes/[id]: エントリが見つからない: ${slug}`);
}
const { Content } = await render(episode);
const { data } = episode;

const pastVersions = (
	await getCollection("episodes", (entry) =>
		entry.id.startsWith(`${data.episodeId}/versions/`),
	)
).sort((a, b) => b.data.revision - a.data.revision);
---

<BaseLayout title={`${data.title} — 歴史スライドラジオ（仮）`} description={data.summary} canonicalPath={`/episodes/${data.episodeId}/`}>
	<EpisodeDetail data={data}>
		<Content />
		<Fragment slot="versions">
			{
				pastVersions.length > 0 && (
					<section data-testid="version-history">
						<h2>過去のバージョン</h2>
						<ul>
							{pastVersions.map((version) => (
								<li>
									<a href={`/episodes/${data.episodeId}/versions/${version.data.revision}/`}>
										revision {version.data.revision}
									</a>
									{version.data.revision === data.revision && "（現行版）"}
								</li>
							))}
						</ul>
					</section>
				)
			}
		</Fragment>
	</EpisodeDetail>
</BaseLayout>
