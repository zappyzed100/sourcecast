---
// index.astro — エピソード一覧（ホームページ）。plan.md Phase 2「一覧」。
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const episodes = (await getCollection("episodes")).sort(
	(a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout
	title="歴史スライドラジオ（仮） — エピソード一覧"
	description="出典付きの日本語台本と音声でお届けする、歴史の小話番組。"
	canonicalPath="/"
>
	<h1>エピソード一覧</h1>

	<p>
		<label for="site-search">サイト内検索</label>
		<input id="site-search" type="search" placeholder="キーワードで検索" data-testid="site-search-input" />
	</p>
	<div id="site-search-results"></div>

	<ul class="episode-list" data-testid="episode-list">
		{
			episodes.map((episode) => (
				<li>
					<a href={`/episodes/${episode.data.episodeId}/`}>{episode.data.title}</a>
					<p>{episode.data.summary}</p>
					<time datetime={episode.data.publishedAt.toISOString()}>
						{episode.data.publishedAt.toISOString().slice(0, 10)}
					</time>
				</li>
			))
		}
	</ul>
</BaseLayout>

<script>
	// 検索UI・索引は検索を使い始めた時だけ読み込む（plan.md §3.1「検索開始時に遅延読み込み」）。
	const input = document.querySelector<HTMLInputElement>('[data-testid="site-search-input"]');
	const resultsEl = document.getElementById("site-search-results");

	interface PagefindResult {
		url: string;
		meta: { title?: string };
		excerpt: string;
	}

	interface PagefindApi {
		search: (term: string) => Promise<{ results: { id: string; data: () => Promise<PagefindResult> }[] }>;
	}

	let pagefindPromise: Promise<PagefindApi> | null = null;

	function loadPagefind(): Promise<PagefindApi> {
		if (!pagefindPromise) {
			// public/scripts/pagefind-bridge.js を <script type="module" src="..."> として
			// 実行時にDOM挿入する(index.astro内で直接 import() しない)。理由は同ファイルの
			// 冒頭コメントに書いたとおり: Viteのimport()ラップ(__VITE_PRELOAD__)がビルド
			// グラフ外のパスで壊れることと、CSP(script-src)がnew Function等を許可しない
			// (Astro CSPが自動付与するハッシュは静的HTML内のインラインscript用で、実行時に
			// 挿入するscriptには及ばない——外部src+'self'ならハッシュ無しで許可される)。
			pagefindPromise = new Promise<PagefindApi>((resolve) => {
				window.addEventListener(
					"pagefind-bridge:loaded",
					(e) => resolve((e as CustomEvent<PagefindApi>).detail),
					{ once: true },
				);
				const script = document.createElement("script");
				script.type = "module";
				script.src = "/scripts/pagefind-bridge.js";
				document.head.appendChild(script);
			});
		}
		return pagefindPromise;
	}

	input?.addEventListener("focus", () => void loadPagefind(), { once: true });

	input?.addEventListener("input", async () => {
		const term = input.value.trim();
		if (!resultsEl) return;
		if (term.length === 0) {
			resultsEl.innerHTML = "";
			return;
		}
		const pagefind = await loadPagefind();
		const search = await pagefind.search(term);
		const entries = await Promise.all(search.results.slice(0, 10).map((r) => r.data()));
		resultsEl.innerHTML = entries
			.map((e) => `<p><a href="${e.url}">${e.meta.title ?? e.url}</a><br>${e.excerpt}</p>`)
			.join("");
	});
</script>

<style>
	.episode-list {
		list-style: none;
		padding: 0;
	}
	.episode-list li {
		margin-bottom: 1.5rem;
	}
</style>
