---
// EpisodeDetail.astro — エピソード詳細の共通表示(episodes/[id]とversions/[revision]で共有)。
// 台本・出典・主張対応・訂正履歴・関連書籍の描画をここに集約する(重複防止)。
import AudioPlayer from "./AudioPlayer.astro";

interface Source {
	name: string;
	url: string;
	license: string;
	credit: string;
	accessedAt: Date;
}
interface Claim {
	text: string;
	sourceIndexes: number[];
}
interface Correction {
	date: Date;
	description: string;
}
interface RelatedBook {
	title: string;
	author: string;
	url: string;
}
interface Chapter {
	title: string;
	startSeconds: number;
}

interface EpisodeData {
	episodeId: string;
	revision: number;
	title: string;
	summary: string;
	publishedAt: Date;
	updatedAt: Date;
	sources: Source[];
	claims: Claim[];
	corrections: Correction[];
	relatedBooks: RelatedBook[];
	audioUrl?: string;
	chapters?: Chapter[];
}

interface Props {
	data: EpisodeData;
	scriptText: string;
	downloadHref: string;
}

const { data, scriptText, downloadHref } = Astro.props;
---

<article data-testid="episode-detail" data-revision={data.revision}>
	<slot name="banner" />
	<h1>{data.title}</h1>
	<p>
		公開日: <time datetime={data.publishedAt.toISOString()}>{data.publishedAt.toISOString().slice(0, 10)}</time>
		{data.updatedAt.valueOf() !== data.publishedAt.valueOf() && (
			<>
				（更新日: <time datetime={data.updatedAt.toISOString()}>{data.updatedAt.toISOString().slice(0, 10)}</time>）
			</>
		)}
		（revision {data.revision}）
	</p>

	{data.audioUrl && <AudioPlayer episodeId={data.episodeId} audioUrl={data.audioUrl} chapters={data.chapters ?? []} />}

	<section>
		<h2>台本</h2>
		<div class="script-actions">
			<button type="button" data-testid="copy-script-button">原稿をコピー</button>
			<a data-testid="download-script-link" href={downloadHref} download>原稿をダウンロード（Markdown）</a>
			<span data-testid="copy-script-status" role="status" aria-live="polite"></span>
		</div>
		<textarea data-testid="script-raw-text" hidden readonly>{scriptText}</textarea>
		<slot />
	</section>

	<slot name="diff" />

	{
		data.claims.length > 0 && (
			<section data-testid="claim-evidence-table">
				<h2>主張と出典の対応</h2>
				<table>
					<thead>
						<tr>
							<th scope="col">主張</th>
							<th scope="col">出典</th>
						</tr>
					</thead>
					<tbody>
						{data.claims.map((claim) => (
							<tr>
								<td>{claim.text}</td>
								<td>
									{claim.sourceIndexes.map((i, position) => (
										<>
											{position > 0 && " "}
											{data.sources[i] && (
												<a data-testid="claim-source-link" href={`#source-${i}`}>
													[{i + 1}]
												</a>
											)}
										</>
									))}
								</td>
							</tr>
						))}
					</tbody>
				</table>
			</section>
		)
	}

	<section data-testid="sources-list">
		<h2>出典・クレジット</h2>
		<ul>
			{data.sources.map((source, i) => (
				<li id={`source-${i}`}>
					[{i + 1}] <a href={source.url}>{source.name}</a>（{source.license}・{source.credit}・閲覧日{" "}
					{source.accessedAt.toISOString().slice(0, 10)}）
				</li>
			))}
		</ul>
	</section>

	{
		data.corrections.length > 0 && (
			<section data-testid="corrections-list">
				<h2>訂正履歴</h2>
				<ul>
					{data.corrections.map((correction) => (
						<li>
							<time datetime={correction.date.toISOString()}>
								{correction.date.toISOString().slice(0, 10)}
							</time>
							: {correction.description}
						</li>
					))}
				</ul>
			</section>
		)
	}

	{
		data.relatedBooks.length > 0 && (
			<section data-testid="related-books">
				<h2>関連書籍</h2>
				<ul>
					{data.relatedBooks.map((book) => (
						<li>
							<a href={book.url}>{book.title}</a>（{book.author}）
						</li>
					))}
				</ul>
				<p><small>上記リンクにはアフィリエイトが含まれる場合があります。</small></p>
			</section>
		)
	}

	<slot name="versions" />
</article>

<script>
	// クリップボードAPIで原稿全文をコピーする(仕様書§10B「コピー可能な原稿全文」)。
	const article = document.querySelector('[data-testid="episode-detail"]');
	const button = article?.querySelector('[data-testid="copy-script-button"]');
	const status = article?.querySelector('[data-testid="copy-script-status"]');
	const rawText = article?.querySelector<HTMLTextAreaElement>('[data-testid="script-raw-text"]');

	button?.addEventListener("click", async () => {
		if (!rawText || !status) return;
		try {
			await navigator.clipboard.writeText(rawText.value);
			status.textContent = "コピーしました";
		} catch {
			status.textContent = "コピーに失敗しました";
		}
	});
</script>
