{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "`sources`/`source_registry`（仕様書§5.14・§5.2）: ソース単位の利用区分・権利条件。",
  "properties": {
    "attribution": {
      "enum": [
        "required",
        "not_required",
        "required_if_not_cc0"
      ],
      "title": "Attribution",
      "type": "string"
    },
    "commercial_use": {
      "enum": [
        "allow",
        "deny",
        "conditional"
      ],
      "title": "Commercial Use",
      "type": "string"
    },
    "modification": {
      "enum": [
        "allow",
        "deny",
        "conditional"
      ],
      "title": "Modification",
      "type": "string"
    },
    "normalized_license_id": {
      "minLength": 1,
      "title": "Normalized License Id",
      "type": "string"
    },
    "recheck_days": {
      "exclusiveMinimum": 0,
      "title": "Recheck Days",
      "type": "integer"
    },
    "redistribution": {
      "enum": [
        "allow",
        "deny",
        "conditional"
      ],
      "title": "Redistribution",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "share_alike": {
      "enum": [
        "none",
        "preserve_per_asset"
      ],
      "title": "Share Alike",
      "type": "string"
    },
    "source_id": {
      "minLength": 1,
      "title": "Source Id",
      "type": "string"
    },
    "status": {
      "enum": [
        "candidate",
        "approved",
        "suspended",
        "rejected"
      ],
      "title": "Status",
      "type": "string"
    },
    "terms_checked_at": {
      "format": "date-time",
      "title": "Terms Checked At",
      "type": "string"
    },
    "terms_url": {
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "title": "Terms Url",
      "type": "string"
    },
    "territory": {
      "minLength": 1,
      "title": "Territory",
      "type": "string"
    },
    "third_party_exception": {
      "enum": [
        "allow",
        "deny"
      ],
      "title": "Third Party Exception",
      "type": "string"
    },
    "use_class": {
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ],
      "title": "Use Class",
      "type": "string"
    }
  },
  "required": [
    "source_id",
    "status",
    "use_class",
    "normalized_license_id",
    "commercial_use",
    "modification",
    "redistribution",
    "attribution",
    "share_alike",
    "third_party_exception",
    "territory",
    "terms_url",
    "terms_checked_at",
    "recheck_days"
  ],
  "title": "SourceRecord",
  "type": "object"
}
