{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "追記型監査ログ（仕様書§15: 公開・訂正・削除・権利判定変更を必ず記録する）。",
  "properties": {
    "action": {
      "minLength": 1,
      "title": "Action",
      "type": "string"
    },
    "actor": {
      "minLength": 1,
      "title": "Actor",
      "type": "string"
    },
    "detail": {
      "default": "",
      "title": "Detail",
      "type": "string"
    },
    "entity_id": {
      "minLength": 1,
      "title": "Entity Id",
      "type": "string"
    },
    "entity_type": {
      "minLength": 1,
      "title": "Entity Type",
      "type": "string"
    },
    "event_id": {
      "minLength": 1,
      "title": "Event Id",
      "type": "string"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "required": [
    "event_id",
    "entity_type",
    "entity_id",
    "action",
    "actor",
    "occurred_at"
  ],
  "title": "AuditEvent",
  "type": "object"
}
